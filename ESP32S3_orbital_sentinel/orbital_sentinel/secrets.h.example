/**
 * @file secrets.h.example
 * @brief Template for Wi-Fi credentials.
 * @details
 *     Copy this file to `secrets.h` and fill in your network. `secrets.h` is
 *     git-ignored so your credentials never end up in the repository.
 *
 *         cp secrets.h.example secrets.h
 *
 *     The ESP32-S3 has a 2.4 GHz radio only - it cannot join a 5 GHz-only SSID.
 *
 *     With no credentials (or no network) the firmware still boots: it falls back
 *     to the element sets baked into tle_fallback.h and keeps the RTC's time.
 */

#ifndef ORBITAL_SENTINEL_SECRETS_H
#define ORBITAL_SENTINEL_SECRETS_H

#define WIFI_SSID "your-2.4GHz-network"
#define WIFI_PASS "your-password"

#endif  // ORBITAL_SENTINEL_SECRETS_H
